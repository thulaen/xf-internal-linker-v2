{
  "HttpWorker": {
    "SchemaVersion": "v1",
    "Redis": {
      "ConnectionString": "redis:6379",
      "JobQueueKey": "http_worker:jobs",
      "ResultTtlSeconds": 3600,
      "DeadLetterTtlSeconds": 86400
    },
    "Http": {
      "DefaultTimeoutSeconds": 30,
      "MaxConcurrency": 100,
      "MaxBodyBytes": 5242880,
      "MaxRedirectHops": 3,
      "ImportMaxPages": 100
    },
    "Postgres": {
      "ConnectionString": ""
    },
    "Scheduler": {
      "Enabled": false,
      "OwnershipMode": "shadow",
      "PollSeconds": 30,
      "ControlPlaneBaseUrl": "http://backend:8000",
      "ControlPlaneToken": ""
    },
    "Progress": {
      "StreamPrefix": "runtime:progress",
      "StreamTtlSeconds": 3600,
      "MaxLen": 512
    }
  }
}
