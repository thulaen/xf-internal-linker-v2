# ═══════════════════════════════════════════════════════════════════
# XF Internal Linker V2 — Production env-var overrides (example)
#
# HOW TO USE:
#   1. Keep your regular .env in place (copied from .env.example).
#   2. Copy this file:   cp .env.prod.example .env.prod
#   3. Fill in the prod-specific values below.
#   4. Start the stack in prod mode:
#        docker compose \
#          --env-file .env \
#          --env-file .env.prod \
#          -f docker-compose.yml \
#          -f docker-compose.prod.yml \
#          up --build
#
# This file is small on purpose — docker-compose.prod.yml handles most
# of the "dev mode off" flips (DJANGO_SETTINGS_MODULE, removing
# uvicorn --reload, swapping frontend to the static bundle, etc.).
# You only need to set what is truly deployment-specific.
# ═══════════════════════════════════════════════════════════════════

# ── Django (backend) ──────────────────────────────────────────────
# Host names that may serve the API. For local prod runs keep
# localhost; for a real deployment put your domain(s) here.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Origins allowed to call the API via CORS. Adjust for your domain.
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# ── HTTPS hardening (set to True for a real HTTPS deployment) ─────
# For a LOCAL prod-mode run over plain HTTP leave these blank — the
# compose override already defaults each to False so login still
# works without TLS. Set to True when you put this behind a real
# HTTPS terminator.
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_SESSION_COOKIE_SECURE=True
# DJANGO_CSRF_COOKIE_SECURE=True
# DJANGO_SECURE_HSTS_SECONDS=31536000

# Rotate this for production. Generate a new value with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Leave blank to keep the .env value (fine for a local prod run).
# DJANGO_SECRET_KEY=

# ── Email (real SMTP in production) ───────────────────────────────
# production.py already defaults to SMTP; fill in if you use it.
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# ── GlitchTip (optional — opt-in via --profile debug) ─────────────
# GLITCHTIP_SECRET_KEY=

# ── Notes ─────────────────────────────────────────────────────────
# You do NOT need to set these here — docker-compose.prod.yml forces
# them inside the containers:
#   DJANGO_DEBUG=False
#   DJANGO_SETTINGS_MODULE=config.settings.production
#   (no uvicorn --reload, no Angular dev server, no CHOKIDAR polling)
