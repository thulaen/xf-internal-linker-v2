# EditorConfig — https://editorconfig.org
# Tells all editors and AI agents to use consistent formatting.
root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.py]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.cpp]
indent_size = 4

[*.h]
indent_size = 4
