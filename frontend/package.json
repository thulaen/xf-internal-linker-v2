{
  "name": "xf-internal-linker-frontend",
  "version": "2.0.0",
  "description": "XF Internal Linker V2 - Angular 20 frontend",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0 --port 4200 --poll 1000",
    "build": "ng build",
    "build:prod": "ng build --configuration=production",
    "watch": "ng build --watch --configuration=development",
    "test": "ng test",
    "test:ci": "node --max-old-space-size=4096 ./node_modules/@angular/cli/bin/ng test --no-watch --no-progress --browsers=ChromeHeadlessNoSandbox",
    "test:ci:docker": "node --max-old-space-size=768 ./node_modules/@angular/cli/bin/ng test --no-watch --no-progress --browsers=ChromeHeadlessNoSandbox",
    "lint": "ng lint",
    "lint:scss": "stylelint \"src/**/*.scss\"",
    "ui:test": "playwright test",
    "ui:test:a11y": "playwright test tests/a11y.spec.ts",
    "ui:test:headed": "playwright test --headed",
    "ui:test:debug": "playwright test --debug",
    "ui:test:live": "set PLAYWRIGHT_LIVE=1&& set PLAYWRIGHT_NO_WEBSERVER=1&& playwright test tests/live",
    "ui:test:live:headed": "set PLAYWRIGHT_LIVE=1&& set PLAYWRIGHT_NO_WEBSERVER=1&& playwright test tests/live --headed",
    "ui:snap": "playwright test tests/capture/page-snapshot.spec.ts --workers=1",
    "ui:snap:live": "set PLAYWRIGHT_LIVE=1&& set PLAYWRIGHT_NO_WEBSERVER=1&& playwright test tests/capture/page-snapshot.spec.ts --workers=1",
    "format": "prettier --write \"src/**/*.{ts,html,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,json}\"",
    "generate:api": "openapi-typescript ../backend/schema.yml -o src/app/api/schema.d.ts",
    "analyze": "ng build --configuration=production --source-map && source-map-explorer \"dist/xf-internal-linker-frontend/browser/*.js\""
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.18",
    "@angular/cdk": "^20.2.11",
    "@angular/common": "^20.3.18",
    "@angular/compiler": "^20.3.18",
    "@angular/core": "^20.3.18",
    "@angular/forms": "^20.3.18",
    "@angular/material": "^20.2.11",
    "@angular/platform-browser": "^20.3.18",
    "@angular/platform-browser-dynamic": "^20.3.18",
    "@angular/router": "^20.3.18",
    "@angular/service-worker": "^20.3.19",
    "@sentry/angular": "^9.47.1",
    "chart.js": "^4.4.7",
    "d3": "^7.9.0",
    "material-icons": "^1.13.14",
    "ng2-charts": "^10.0.0",
    "ngx-monaco-editor-v2": "^19.0.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.0",
    "web-vitals": "^4.2.4"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.21",
    "@angular-eslint/builder": "^21.3.1",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/cli": "^20.3.21",
    "@angular/compiler-cli": "^20.3.18",
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.54.2",
    "@testing-library/angular": "^17.3.6",
    "@testing-library/jest-dom": "^6.4.6",
    "@types/d3": "^7.4.3",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^22.0.0",
    "angular-eslint": "^21.3.1",
    "eslint": "^10.2.0",
    "jasmine-core": "~5.5.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "openapi-typescript": "^7.4.0",
    "prettier": "^3.3.3",
    "source-map-explorer": "^2.5.3",
    "stylelint": "^17.9.1",
    "stylelint-config-recommended-scss": "^17.0.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.58.0",
    "zone.js": "~0.15.0"
  }
}
