#!/bin/bash
# Automatically enforce test checks before pushing to repository
# This prevents AI agents and developers from breaking CI with bad commits.

REPO_ROOT="$(git rev-parse --show-toplevel)"

echo "========================================="
echo "Running Pre-push checks (Full verify + prune)"
echo "========================================="

# 1. Auto-generate any missing Django migrations and commit them
echo "=> Checking Django migrations..."
cd "$REPO_ROOT/backend" || exit 1
export DJANGO_SETTINGS_MODULE=config.settings.ci
export DJANGO_SECRET_KEY=ci-fake-secret-key
python manage.py makemigrations
if [ $? -ne 0 ]; then
  echo "[ERROR] makemigrations failed. Push aborted."
  exit 1
fi

# If new migration files were created, auto-commit them
NEW_MIGRATIONS=$(git -C "$REPO_ROOT" status --short -- backend/ | grep -E "^\?\?|^A |^ M" | grep "migrations/")
if [ -n "$NEW_MIGRATIONS" ]; then
  echo "=> New migrations detected — committing automatically..."
  git -C "$REPO_ROOT" add backend/
  git -C "$REPO_ROOT" commit -m "chore(migrations): auto-generate missing migrations [pre-push]"
  if [ $? -ne 0 ]; then
    echo "[ERROR] Failed to commit auto-generated migrations. Push aborted."
    exit 1
  fi
fi

# Confirm no further migrations are needed
python manage.py makemigrations --check --dry-run
if [ $? -ne 0 ]; then
  echo "[ERROR] Migration check failed even after auto-generate. Push aborted."
  exit 1
fi
cd "$REPO_ROOT"

# 2. Full local verification (C++, backend, frontend, HttpWorker, plus artifact prune)
echo "=> Running full local verification..."
powershell.exe -ExecutionPolicy Bypass -File "$REPO_ROOT/scripts/verify.ps1"
if [ $? -ne 0 ]; then
  echo "[ERROR] Full local verification failed. Push aborted."
  exit 1
fi

# 3. Docker Compose validation
echo "=> Validating docker-compose.yml..."
cp "$REPO_ROOT/.env.example" "$REPO_ROOT/.env"
docker compose -f "$REPO_ROOT/docker-compose.yml" config > /dev/null
if [ $? -ne 0 ]; then
  echo "[ERROR] docker-compose.yml is invalid. Push aborted."
  exit 1
fi

# 4. Business Logic Checklist reminder
BUSINESS_LOGIC_DIRS=(
  "backend/apps/pipeline"
  "backend/apps/analytics"
  "backend/apps/cooccurrence"
)
STAGED_FILES=$(git diff --cached --name-only 2>/dev/null)
for DIR in "${BUSINESS_LOGIC_DIRS[@]}"; do
  if echo "$STAGED_FILES" | grep -q "^$DIR"; then
    echo ""
    echo "========================================="
    echo "  REMINDER: Business logic files staged."
    echo "  Did you complete docs/BUSINESS-LOGIC-CHECKLIST.md"
    echo "  before writing this code? All 7 sections"
    echo "  (0-6) must be checked or justified."
    echo "========================================="
    echo ""
    break
  fi
done

echo "========================================="
echo "All checks passed! Push proceeding..."
echo "========================================="
exit 0
