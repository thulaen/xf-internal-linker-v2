# ═══════════════════════════════════════════════════════════════════
# XF Internal Linker V2 — Environment Variables
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your values below
#   3. NEVER commit .env to git — it is already in .gitignore
#
# All secrets live here. Nothing is hardcoded in the application.
# ═══════════════════════════════════════════════════════════════════

# ── Django Core ──────────────────────────────────────────────────
# Generate a new secret key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here-generate-a-real-one

# Set to False in production
DJANGO_DEBUG=True

# Comma-separated list of allowed hostnames
# Example for production: yourdomain.com,www.yourdomain.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Django settings module to use
DJANGO_SETTINGS_MODULE=config.settings.development

# ── PostgreSQL Database ───────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=xf_linker
POSTGRES_USER=xf_linker_user
POSTGRES_PASSWORD=changeme_use_a_strong_password

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# Redis database numbers (keep these separate to avoid key collisions)
REDIS_CACHE_DB=1
REDIS_CELERY_DB=2
REDIS_CHANNELS_DB=3

# ── Celery ────────────────────────────────────────────────────────
# Number of parallel worker processes (2 is safe for 16 GB RAM)
CELERY_WORKER_CONCURRENCY=2

# ── ML / AI Performance ───────────────────────────────────────────
# BALANCED = CPU only (safe default for 16 GB RAM)
# HIGH_PERFORMANCE = CPU + GPU (requires NVIDIA GPU + CUDA)
ML_PERFORMANCE_MODE=BALANCED

# Batch size for generating embeddings (reduce if running out of RAM)
EMBEDDING_BATCH_SIZE=32

# sentence-transformers model name (download on first use)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# spaCy model (installed in Dockerfile)
SPACY_MODEL=en_core_web_sm

# ── XenForo API ───────────────────────────────────────────────────
# Your XenForo forum URL (no trailing slash)
XENFORO_BASE_URL=https://your-forum.com

# XenForo REST API key (Admin → API Keys → Create new)
# This is READ-ONLY — the app NEVER writes to XenForo
XENFORO_API_KEY=your-xenforo-api-key-here

# ── WordPress API (optional — for cross-linking) ─────────────────
# WordPress site URL (no trailing slash)
WORDPRESS_BASE_URL=https://your-wordpress-site.com

# WordPress Application Password (Users → Profile → Application Passwords)
# This is READ-ONLY — the app NEVER writes to WordPress
WORDPRESS_USERNAME=your-wp-username
WORDPRESS_APP_PASSWORD=your-wp-application-password

# ── Google Search Console (optional) ─────────────────────────────
# OAuth2 client credentials from Google Cloud Console
# Download the JSON from: console.cloud.google.com → APIs & Services → Credentials
GSC_CLIENT_ID=your-gsc-client-id
GSC_CLIENT_SECRET=your-gsc-client-secret
GSC_REDIRECT_URI=http://localhost:8000/api/analytics/gsc/callback/

# ── Google Analytics 4 (optional) ────────────────────────────────
GA4_PROPERTY_ID=your-ga4-property-id
GA4_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# Path to the service account JSON key file (mounted into Docker)
GA4_SERVICE_ACCOUNT_KEY_PATH=/app/secrets/ga4-service-account.json

# ── SSH Sync (optional — for local file sync) ─────────────────────
SSH_HOST=your-server-hostname
SSH_PORT=22
SSH_USER=your-ssh-username
SSH_KEY_PATH=/app/secrets/id_rsa
SSH_REMOTE_PATH=/path/to/remote/data

# ── CORS ─────────────────────────────────────────────────────────
# Angular dev server — add more if needed
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# ── Email (optional — for error alerts) ──────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ── Cache TTLs (seconds) ──────────────────────────────────────────
CACHE_TTL_PIPELINE=3600
CACHE_TTL_XENFORO_API=900
CACHE_TTL_GSC=21600
CACHE_TTL_PAGERANK=3600
